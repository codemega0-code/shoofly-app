generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  password       String
  phone          String?
  role           String     @default("CLIENT")
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  requests       Request[]  @relation("ClientRequests")
  bids           Bid[]      @relation("VendorBids")
  deliveries     Delivery[] @relation("DeliveryTasks")
  deposits       Deposit[]  @relation("ClientDeposits")
  disputesRaised Dispute[]  @relation("DisputeRaiser")
}

model Request {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  description String
  imageUrl    String?
  location    String
  phone       String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      User     @relation("ClientRequests", fields: [clientId], references: [id])
  bids        Bid[]
  order       Order?
}

model Bid {
  id           String   @id @default(cuid())
  requestId    String
  vendorId     String
  price        Float
  deliveryTime String
  notes        String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  request      Request  @relation(fields: [requestId], references: [id])
  vendor       User     @relation("VendorBids", fields: [vendorId], references: [id])
  order        Order?
}

model Order {
  id              String   @id @default(cuid())
  requestId       String   @unique
  bidId           String   @unique
  clientId        String
  vendorId        String
  totalPrice      Float
  depositRequired Boolean  @default(false)
  depositAmount   Float?
  status          String   @default("CONFIRMED")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  request         Request  @relation(fields: [requestId], references: [id])
  bid             Bid      @relation(fields: [bidId], references: [id])
  deposit         Deposit?
  delivery        Delivery?
  dispute         Dispute?
}

model Deposit {
  id        String   @id @default(cuid())
  orderId   String   @unique
  clientId  String
  amount    Float
  method    String
  proofUrl  String?
  status    String   @default("PENDING")
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order    @relation(fields: [orderId], references: [id])
  client    User     @relation("ClientDeposits", fields: [clientId], references: [id])
}

model Delivery {
  id             String    @id @default(cuid())
  orderId        String    @unique
  deliveryUserId String?
  status         String    @default("AVAILABLE")
  failReason     String?
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order          Order     @relation(fields: [orderId], references: [id])
  deliveryUser   User?     @relation("DeliveryTasks", fields: [deliveryUserId], references: [id])
}

model Dispute {
  id         String   @id @default(cuid())
  orderId    String   @unique
  raisedById String
  reason     String
  status     String   @default("OPEN")
  resolution String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order      Order    @relation(fields: [orderId], references: [id])
  raisedBy   User     @relation("DisputeRaiser", fields: [raisedById], references: [id])
}
